# Look and feel
font-family = Hack Nerd Font Mono
font-style = Regular
font-size = 11
theme = TokyoNight
window-decoration = auto

background-opacity = 0.0

# Create splits and tabs
keybind = ctrl+a>right=new_split:right
keybind = ctrl+a>up=new_split:up
keybind = ctrl+a>left=new_split:left
keybind = ctrl+a>down=new_split:down
keybind = ctrl+a>t=new_tab

# Split navigation
keybind = ctrl+left=goto_split:left
keybind = ctrl+right=goto_split:right
keybind = ctrl+up=goto_split:up
keybind = ctrl+down=goto_split:down
keybind = ctrl+a>z=toggle_split_zoom
 # This closes whatever is currently 'selected'. Be it split, tab or window
keybind = ctrl+a>c=close_surface

# Muscle-memory helpers
keybind = ctrl+shift+s=paste_from_selection

shell-integration-features = sudo,ssh-env,ssh-terminfo