[{
    "output": ["Dell Inc. DELL P3424WE FG8Z5T3", "Samsung Electric Company C27HG7x HTNK700263", "eDP-1"],
    "modules-left": ["custom/os_button","custom/separator#dot-line", "hyprland/workspaces", "custom/separator#dot-line", "idle_inhibitor", "custom/check-wireguard"],
    "modules-center": ["clock"],
    "margin": "0 0 0 0",
    "reload_style_on_change": true,
    "modules-right": ["group/expand", "custom/separator#dot-line", "cpu", "memory", "custom/disk", "temperature", "group/expandVol", "pulseaudio", "battery", "network", "power-profiles-daemon", "custom/notification"],

    // Used as a nice graphical divider
    "custom/separator#dot-line": {
        "format": "ν‰Γ",
        "interval": "once",
        "tooltip": false
    },

    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "urgent": "ο¹Σ",
            "active": "ο³ë", // focused workspace on current monitor
            "visible": "ο³ë", // focused workspace on other monitors
            "default": "ο³¨",
            "empty": "ο³¨" // persistent (created by this plugin)
        },
        "all-outputs": false,
        "active-only": true,
        "persistent-workspaces": {
