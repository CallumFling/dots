    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "ο¹°",
            "deactivated": "ο¹Α"
        }
    },
    "tray": {
        "spacing": 10
    },

    "clock": {
        "format": "{:%e %b %H:%M:%S}",
        "interval": 1,
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode"          : "year",
            "mode-mon-col"  : 3,
            "weeks-pos"     : "right",
            "on-scroll"     : 1,
            "format": {
                "months":   "<span color='#7aa2f7'><b>{}</b></span>",   /* blue */
                "days":     "<span color='#9ece6a'><b>{}</b></span>",   /* green */
                "weeks":    "<span color='#7dcfff'><b>W{}</b></span>",  /* cyan */
                "weekdays": "<span color='#e0af68'><b>{}</b></span>",   /* yellow */
                "today":    "<span color='#ff9e64'><b><u>{}</u></b></span>" /* orange */
