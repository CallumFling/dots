        "states": {
            "warning": 30,
            "critical": 15
        },
        // Connected to AC
        "format": "<span color='#0DB9D7'>οÉß</span> {capacity}%", // Icon: bolt
        // Not connected to AC
        "format-discharging": "{icon} {capacity}%",
        "format-plugged": "<span color='#0DB9D7'>ο΅Π</span> {capacity}%",
        "format-icons": [
            "<span color='#c53b53'>σΑ¹Κ</span>",
            "<span color='#0DB9D7'>σΑ¹Μ</span>",
            "<span color='#0DB9D7'>σΑ¹Φ</span>",
            "<span color='#0DB9D7'>σΑ¹Ϋ</span>",
            "<span color='#0DB9D7'>σΑ¹Ψ</span>",
            "<span color='#0DB9D7'>σΑ¹Ω</span>",
            "<span color='#0DB9D7'>σΑ¹Ϋ</span>",
            "<span color='#0DB9D7'>σΑ²Ä</span>",
