        "interval": 1,
        "format": "{icon}",
        "format-icons": ["σΑùΠ","σΑΣû","σΑΣü","σΑΣ†","σΑΣΓ","σΑΣΔ","σΑΣΘ","σΑΣΛ","σΑΣΞ"]
    },

    "custom/disk": {
        "interval": 10,
        "exec": "bash $HOME/.config/waybar/disk-percentage.sh 2> /dev/null",
        "return-type": "json",
        "format": "{icon}",
        "format-icons": ["σΑùΠ","σΑΣû","σΑΣü","σΑΣ†","σΑΣΓ","σΑΣΔ","σΑΣΘ","σΑΣΛ","σΑΣΞ"]
    },

    "custom/check-wireguard": {
        "interval": 5,
        "exec": "bash $HOME/.config/waybar/wireguard-check.sh 2> /dev/null",
        "return-type": "json",
        "format": "{}"
    },

    "battery": {
