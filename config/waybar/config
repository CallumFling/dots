    "group/expand": {
            "orientation": "horizontal",
            "drawer": {
                "transition-duration": 600,
                "transition-to-left": true,
                "click-to-reveal": false
            },
            "modules": ["custom/expand", "tray"]
        },

    "group/expandVol": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 600,
            "transition-to-left": true,
            "click-to-reveal": false
        },
        "modules": ["custom/expandVol", "pulseaudio/slider"]
    },

    "custom/notification": {
