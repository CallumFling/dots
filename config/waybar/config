      "interval": 2,
      "hwmon-path-abs": "/sys/devices/platform/coretemp.0/hwmon/",
      "input-filename": "temp1_input",
      "format": "{icon} {temperatureC}¬ΑC",
      "format-icons": [
          "<span color='#0DB9D7'>ο΄΄</span>", // Icon: temperature-empty
          "<span color='#0DB9D7'>ο΄ä</span>", // Icon: temperature-quarter
          "<span color='#0DB9D7'>ο΄â</span>", // Icon: temperature-half
          "<span color='#0DB9D7'>ο΄à</span>", // Icon: temperature-three-quarters
          "<span color='#c53b53'>ο΄à</span>"  // Icon: temperature-full
